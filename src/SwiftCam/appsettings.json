{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Camera": {
    "Width": 640,
    "Height": 480,
    "Framerate": 15,
    "Quality": 80
  },
  "Motion": {
    "Threshold": 5.0,
    "CooldownSeconds": 300,
    "CaptureDirectory": "captures",
    "PixelTolerance": 30
  }
}
